        <div data-widget_type="widget" data-widget_name="BangladeshHeaderWidget" class="widget bangladesh-header-widget"> <div class="header-date-lang-container"> <p class="bangladesh-header-widget-current-date"> ১৭ এপ্রিল ২০২৬ </p> <div class="bangladesh-header-widget-dropdown"> <button type="button" class="bangladesh-header-widget-dropdown-toggle"> <span id="bangladesh-header-widget-current-lang">BN</span> <img src="/site-assets/images/down-arrow.svg" class="bangladesh-header-widget-arrow" width="10" height="10" alt="Arrow" /> </button> <div class="bangladesh-header-widget-dropdown-menu"> <a href="#" class="bangladesh-header-widget-dropdown-item" data-value="bn" data-lang="BN">বাংলা (BN)</a> <a href="#" class="bangladesh-header-widget-dropdown-item" data-value="en" data-lang="EN">English (EN)</a> </div> </div> </div> <div class="header-main-container"> <div class="header-main-container-left-section"> <img class="office-logo" src="/site-assets/images/logo.png" alt="Office Logo"> <a class="header-title" href="/" title="বাংলাদেশ জাতীয় তথ্য বাতায়ন"> বাংলাদেশ জাতীয় তথ্য বাতায়ন </a> </div> <div class="global-searchbar custom-items-center "> <div class='widget global-search-widget'> <input class="input-search" id="7048531812" name="key" placeholder="এখানে খুঁজুন..." onkeypress="window.handleSearchEnter('7048531812', arguments[0])"/> <button type="button" class="btn-search" onclick="window.handleSearchClick('7048531812')"> অনুসন্ধান </button> </div> </div> <div class="header-main-container-right-section"> <div class="widget social-link-media-widget"> </div> </div> </div> </div> 
